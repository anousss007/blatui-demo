APP_NAME=BlatUI
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://demo.blatui.dev

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Brand (config/brand.php reads these)
BRAND_NAME=BlatUI
BRAND_GITHUB=https://github.com/anousss007/blatui

LOG_CHANNEL=stack
LOG_LEVEL=warning

# No database needed — the demo renders static Blade. Keep the null/sqlite
# defaults so nothing tries to connect at boot.
DB_CONNECTION=sqlite

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
CACHE_STORE=file
FILESYSTEM_DISK=local

VITE_APP_NAME="${APP_NAME}"
